<Window x:Class="SubnetCalculator.WindowResult"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SubnetCalculator"
        mc:Ignorable="d"
        Title="Класс IP-адреса" Height="300" Width="400"
        Icon="C:\Users\Danila\source\repos\SubnetCalculator\SubnetCalculator\Icon\network_earth.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtClassLetter" Grid.Row="0"
                   FontSize="64" FontWeight="Bold"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <Rectangle Grid.Row="1" Height="2" Fill="LightGray" Margin="0,5,0,5"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="txtDescription" TextWrapping="Wrap" FontSize="14" Margin="0,5"/>
        </ScrollViewer>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="txtRange" TextWrapping="Wrap" FontSize="12" Foreground="Gray" Margin="0,5"/>
        </ScrollViewer>

        <Button Grid.Row="4" Content="OK" Width="80" Height="30"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Click="OkButton_Click"/>

    </Grid>
</Window>
