<Window x:Class="SubnetCalculator.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SubnetCalculator"
        mc:Ignorable="d"
        Icon="C:\Users\Danila\source\repos\SubnetCalculator\SubnetCalculator\Icon\question.png"
        Title="Справка" Height="300" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Подробное описание" FontWeight="Bold" FontSize="16" Margin="150,0,0,15"/>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,30,0,0">
            <TextBlock x:Name="txtHelpContent" TextWrapping="Wrap" FontSize="14" 
                       Foreground="#333333" LineHeight="1.4"/>
        </ScrollViewer>

        <Button x:Name="Btn_Ok" Grid.Row="1" Height="25" Width="70" Content="Выход" 
                Click="Btn_Ok_Click" Margin="390,-55,0,0"/>

    </Grid>
</Window>
