<Window x:Class="SubnetCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SubnetCalculator"
        mc:Ignorable="d"
        Title="IP-Lab" Height="450" Width="600"
        WindowStartupLocation="CenterScreen"
        Icon="C:\Users\Danila\source\repos\SubnetCalculator\SubnetCalculator\Icon\tools.ico">
    <Grid>
        <!-- Фоновое изображение -->
        <Image Source="Image/smeshariki_MainWindow_Background.png" 
               Stretch="UniformToFill" 
               Panel.ZIndex="-1" />

        <!-- Основной контент с отступами -->
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель -->
            <Border Background="#2C3E50" Padding="10" CornerRadius="5" Grid.Row="0">
                <TextBlock Text="Сетевые помощники" FontSize="22" Foreground="White"/>
            </Border>

            <!-- Кнопки -->
            <WrapPanel Grid.Row="1" Margin="0,20" HorizontalAlignment="Center">
                <Button Width="150" Height="100" Margin="10" Click="OpenSubnetCalculator_Click">
                    <StackPanel>
                        <TextBlock Text="🧮" FontSize="32" TextAlignment="Center"/>
                        <TextBlock Text="Калькулятор подсетей" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
                
                <Button Width="150" Height="100" Margin="10" Click="ShowPlaceholder_Click">
                    <StackPanel>
                        <TextBlock Text="📁" FontSize="32"/>
                        <TextBlock Text="Проект 2" TextAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Width="150" Height="100" Margin="10" Click="ShowPlaceholder_Click">
                    <StackPanel>
                        <TextBlock Text="📁" FontSize="32"/>
                        <TextBlock Text="Проект 3" TextAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Width="150" Height="100" Margin="10" Click="ShowPlaceholder_Click">
                    <StackPanel>
                        <TextBlock Text="📁" FontSize="32"/>
                        <TextBlock Text="Проект 4" TextAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Width="150" Height="100" Margin="10" Click="ShowPlaceholder_Click">
                    <StackPanel>
                        <TextBlock Text="📁" FontSize="32"/>
                        <TextBlock Text="Проект 5" TextAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Width="150" Height="100" Margin="10" Click="ShowPlaceholder_Click">
                    <StackPanel>
                        <TextBlock Text="📁" FontSize="32"/>
                        <TextBlock Text="Проект 6" TextAlignment="Center"/>
                    </StackPanel>
                </Button>
                
            </WrapPanel>
        </Grid>
    </Grid>
</Window>