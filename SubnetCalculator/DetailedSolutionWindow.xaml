<Window x:Class="SubnetCalculator.DetailedSolutionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подробное решение" Height="600" Width="850"
        Icon="C:\Users\Danila\source\repos\SubnetCalculator\SubnetCalculator\Icon\lightbulb.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Пошаговый расчёт подсети" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,10">

                <!-- Блок 1: Исходные данные -->
                <Border Background="#F0F0F0" Padding="10" Margin="0,5" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="📌 Исходные данные" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding IP}" Margin="0,5,0,0"/>
                        <TextBlock Text="{Binding Mask}" Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding Prefix}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Блок 2: Двоичное представление -->
                <Expander Header="⌨️ 1. Перевод в двоичную систему" Margin="0,5" IsExpanded="False">
                    <Border Background="#FAFAFA" Padding="10" Margin="0,5" CornerRadius="3">
                        <StackPanel>
                            <TextBlock Text="{Binding DetailedBinaryExplanation}" TextWrapping="Wrap" 
                                       FontSize="13" LineHeight="1.4"/>
                            <TextBlock Text="IP (двоично):" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding IPBinary}" FontFamily="Consolas"/>
                            <TextBlock Text="Маска (двоично):" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding MaskBinary}" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- Блок 3: Адрес сети -->
                <Expander Header="🌐 2. Адрес сети (IP &amp; Маска)" Margin="0,5">
                    <Border Background="#FAFAFA" Padding="10" Margin="0,5" CornerRadius="3">
                        <StackPanel>
                            <TextBlock Text="{Binding DetailedNetworkExplanation}" TextWrapping="Wrap" 
                                       FontSize="13" LineHeight="1.4"/>
                            <TextBlock Text="Результат (двоично):" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding NetworkBinary}" FontFamily="Consolas"/>
                            <TextBlock Text="Десятичный адрес сети:" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding NetworkIp}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- Блок 4: Широковещательный адрес -->
                <Expander Header="📢 3. Широковещательный адрес (Сеть | ~Маска)" Margin="0,5">
                    <Border Background="#FAFAFA" Padding="10" Margin="0,5" CornerRadius="3">
                        <StackPanel>
                            <TextBlock Text="{Binding DetailedBroadcastExplanation}" TextWrapping="Wrap" 
                                       FontSize="13" LineHeight="1.4"/>
                            <TextBlock Text="Результат (двоично):" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding BroadcastBinary}" FontFamily="Consolas"/>
                            <TextBlock Text="Десятичный широковещательный адрес:" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding BroadcastIp}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- Блок 5: Диапазон узлов -->
                <Expander Header="🖥 4. Диапазон доступных узлов" Margin="0,5">
                    <Border Background="#FAFAFA" Padding="10" Margin="0,5" CornerRadius="3">
                        <StackPanel>
                            <TextBlock Text="{Binding DetailedHostRangeExplanation}" TextWrapping="Wrap" 
                                       FontSize="13" LineHeight="1.4"/>
                            <TextBlock Text="Первый адрес (сеть + 1):" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding FirstHost}" FontFamily="Consolas"/>
                            <TextBlock Text="Последний адрес (broadcast - 1):" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding LastHost}" FontFamily="Consolas"/>
                            <TextBlock Text="{Binding HostCount}" Margin="0,10,0,0" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Expander>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
