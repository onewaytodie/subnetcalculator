<Window x:Class="SubnetCalculator.ScreenSaver"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Загрузка" Height="300" Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid>
        <Image Source="C:\Users\Danila\source\repos\SubnetCalculator\SubnetCalculator\Image\smeshariki.png" 
               Stretch="UniformToFill" 
               StretchDirection="Both"/>
        <Border CornerRadius="10"/>

        <!-- Текст и прогресс-бар поверх картинки -->
        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,20">
            <TextBlock Text="Добро пожаловать!" 
               FontFamily="Comic Sans MS" 
               FontSize="20" 
               FontWeight="Bold"
               Foreground="yellow"
               HorizontalAlignment="Center"
               Margin="0,0,0,5">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.6" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="Загружаем сетевые помощники..." 
               FontFamily="Segoe UI" 
               FontSize="16" 
               Foreground="Yellow"
               HorizontalAlignment="Center"/>
            <ProgressBar IsIndeterminate="True" 
                 Height="12" 
                 Width="250" 
                 Margin="0,15,0,0"
                 HorizontalAlignment="Center"
                 Foreground="White" 
                 Background="Gray"/>
        </StackPanel>
    </Grid>
</Window>
