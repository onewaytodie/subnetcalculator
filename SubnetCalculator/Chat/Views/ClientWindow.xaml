<Window x:Class="SubnetCalculator.Chat.Views.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:local="clr-namespace:SubnetCalculator.Chat.Views"
        Title="Клиент чата" Height="550" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}">
    <Window.Resources>
        <local:OwnMessageBackgroundConverter x:Key="OwnMessageBackgroundConverter"/>
        <local:MessageAlignmentConverter x:Key="MessageAlignmentConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: список пользователей -->
        <ListBox x:Name="UsersListBox"
                 ui:ControlHelper.CornerRadius="8"
                 SelectionChanged="UsersListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <TextBlock Text="🟢" Margin="0,0,8,0" Foreground="LightGreen"/>
                        <TextBlock Text="{Binding}" Foreground="{ui:ThemeResource SystemControlForegroundBaseHighBrush}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Правая область: чат -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Строка подключения -->
            <!-- Строка подключения -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBox x:Name="txtServerIP" Text="127.0.0.1" Width="120" Margin="0,0,10,0"
             ui:ControlHelper.CornerRadius="4"/>
                <TextBox x:Name="txtPort" Text="27015" Width="80" Margin="0,0,10,0"
             ui:ControlHelper.CornerRadius="4"/>
                <Button x:Name="btnConnect" Content="Подключиться" Width="110"
            ui:ControlHelper.CornerRadius="4"
            Click="BtnConnect_Click"/>
                <Button x:Name="btnDisconnect" Content="Отключиться" Width="110" Margin="10,0,0,0"
            IsEnabled="False" ui:ControlHelper.CornerRadius="4"
            Click="BtnDisconnect_Click"/>
            </StackPanel>

            <TextBlock x:Name="ChatTitle" Grid.Row="1" Text="Общий чат" FontSize="16" FontWeight="Bold"
                       Foreground="{ui:ThemeResource SystemControlForegroundBaseHighBrush}" Margin="0,0,0,5"/>

            <ScrollViewer x:Name="MessagesScrollViewer" Grid.Row="2">
                <ItemsControl x:Name="MessagesItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,2" Padding="8" CornerRadius="8"
                                    Background="{Binding IsOwn, Converter={StaticResource OwnMessageBackgroundConverter}}"
                                    HorizontalAlignment="{Binding IsOwn, Converter={StaticResource MessageAlignmentConverter}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Author}" FontWeight="Bold" FontSize="11" Foreground="#AAAAAA"/>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="White"/>
                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" FontSize="10" Foreground="#888" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Row="3" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtMessage" ui:ControlHelper.CornerRadius="4"/>
                <Button x:Name="btnSend" Grid.Column="1" Content="Отправить" Width="80" Margin="5,0,0,0"
                        ui:ControlHelper.CornerRadius="4" Click="SendButton_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>