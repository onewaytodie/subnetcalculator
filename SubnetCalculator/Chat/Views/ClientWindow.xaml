<Window x:Class="SubnetCalculator.Chat.Views.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клиент чата" Height="450" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBox x:Name="txtServerIP" Text="127.0.0.1" Width="100" Margin="0,0,10,0"/>
            <TextBox x:Name="txtPort" Text="27015" Width="80" Margin="0,0,10,0"/>
            <Button x:Name="btnConnect" Content="Подключиться" Width="100" Click="BtnConnect_Click"/>
            <Button x:Name="btnDisconnect" Content="Отключиться" Width="100" Margin="10,0,0,0" IsEnabled="False" Click="BtnDisconnect_Click"/>
        </StackPanel>

        <ListBox x:Name="lstChat" Grid.Row="1" Margin="0,5"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtMessage" Grid.Column="0" Height="30" VerticalContentAlignment="Center"/>
            <Button x:Name="btnSend" Grid.Column="1" Content="Отправить" Width="80" Margin="10,0,0,0" Click="BtnSend_Click" IsEnabled="False"/>
        </Grid>
    </Grid>
</Window>
