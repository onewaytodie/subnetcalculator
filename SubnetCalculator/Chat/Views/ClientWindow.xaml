<Window x:Class="SubnetCalculator.Chat.Views.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SubnetCalculator.Chat.Views"
        Title="Клиент чата" Height="550" Width="920"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">
    <Window.Resources>
        <local:OwnMessageBackgroundConverter x:Key="OwnMessageBackgroundConverter"/>
        <local:MessageAlignmentConverter x:Key="MessageAlignmentConverter"/>

        <SolidColorBrush x:Key="ButtonBg" Color="#2C7BE5"/>
        <SolidColorBrush x:Key="ButtonHover" Color="#1E5EC7"/>
        <SolidColorBrush x:Key="ButtonPressed" Color="#134B8E"/>
        <SolidColorBrush x:Key="BorderDark" Color="#3E3E42"/>
        <SolidColorBrush x:Key="CardBg" Color="#2D2D30"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource ButtonPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#555"/>
                                <Setter Property="Foreground" Value="#999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: список пользователей -->
        <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="10" Margin="0,0,10,0">
            <ListBox x:Name="UsersListBox" 
                     SelectionChanged="UsersListBox_SelectionChanged"
                     Background="Transparent"
                     BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="8,6">
                            <Ellipse Width="10" Height="10" Fill="LightGreen" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding}" Foreground="White" FontSize="13"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Правая область -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Панель подключения -->
            <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="IP:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="txtServerIP" Text="127.0.0.1" Width="100" Margin="0,0,15,0"/>
                    <TextBlock Text="Порт:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="txtPort" Text="27015" Width="80" Margin="0,0,15,0"/>
                    <TextBox x:Name="txtNick" Text="User" Width="100" Margin="0,0,10,0"/>
                    <Button x:Name="btnConnect" Content="Подключиться" Width="100" Click="BtnConnect_Click"/>
                    <Button x:Name="btnDisconnect" Content="Отключиться" Width="100" Margin="10,0,0,0" IsEnabled="False" Click="BtnDisconnect_Click"/>
                </StackPanel>
            </Border>

            <!-- Чат -->
            <Border Grid.Row="1" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="10" Margin="0,0,0,10">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ChatTitle" Text="Общий чат" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                    <ScrollViewer x:Name="MessagesScrollViewer" Grid.Row="1">
                        <ItemsControl x:Name="MessagesItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2" Padding="10" CornerRadius="8"
                                            Background="{Binding IsOwn, Converter={StaticResource OwnMessageBackgroundConverter}}"
                                            HorizontalAlignment="{Binding IsOwn, Converter={StaticResource MessageAlignmentConverter}}"
                                            MaxWidth="400">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Author}" FontWeight="Bold" FontSize="11" Foreground="#CCCCCC"/>
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="White" Margin="0,2,0,2"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" FontSize="10" Foreground="#888" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Панель ввода -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnSendFile" Grid.Column="0" Content="📎" Width="40" Margin="0,0,5,0" 
                        Click="SendFileButton_Click" IsEnabled="False"/>
                <TextBox x:Name="txtMessage" Grid.Column="1" IsEnabled="False"/>
                <Button x:Name="btnSend" Grid.Column="2" Content="Отправить" Width="80" Margin="5,0,0,0" 
                        IsEnabled="False" Click="SendButton_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>