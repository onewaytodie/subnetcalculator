<Window x:Class="SubnetCalculator.Chat.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:local="clr-namespace:SubnetCalculator.Chat.Views"
        Title="Сервер чата" Height="600" Width="950"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">
    <Window.Resources>
        <local:MessageAlignmentConverter x:Key="MessageAlignmentConverter"/>

        <SolidColorBrush x:Key="BorderDark" Color="#3E3E42"/>
        <SolidColorBrush x:Key="CardBg" Color="#2D2D30"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2C7BE5"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1E5EC7"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#134B8E"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#555555"/>
                                <Setter Property="Foreground" Value="#999999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ui:NavigationView x:Name="MainNavView"
                       PaneDisplayMode="LeftCompact"
                       IsBackButtonVisible="Collapsed"
                       IsSettingsVisible="False">
        <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem x:Name="ClientsNavItem" Content="Клиенты" Icon="Contact"/>
        </ui:NavigationView.MenuItems>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель: диалоги и запросы файлов -->
            <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,1,0">
                <StackPanel>
                    <TextBlock Text="Диалоги" FontWeight="Bold" Margin="10,10,0,5" Foreground="White"/>
                    <ListBox x:Name="DialogsListView" 
                             SelectionChanged="DialogsListView_SelectionChanged"
                             Background="Transparent" 
                             BorderThickness="0"
                             Height="300">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="🟢" Margin="0,0,8,0" Foreground="LightGreen"/>
                                    <TextBlock Text="{Binding}" Foreground="White"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Separator Margin="5" Background="{StaticResource BorderDark}"/>

                    
                </StackPanel>
            </Border>

            <!-- Правая область: чат -->
            <Grid Grid.Column="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer x:Name="MessagesScrollViewer" Grid.Row="0">
                    <ItemsControl x:Name="MessagesItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,2" Padding="8" CornerRadius="8"
                                        HorizontalAlignment="{Binding IsOwn, Converter={StaticResource MessageAlignmentConverter}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#3E3E42"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOwn}" Value="True">
                                                    <Setter Property="Background" Value="#2C7BE5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Author}" FontWeight="Bold" FontSize="11" Foreground="#CCCCCC"/>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="White" Margin="0,2,0,2"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" FontSize="10" Foreground="#888" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="MessageTextBox" IsEnabled="False"/>
                    <Button x:Name="SendButton" Grid.Column="1" Content="Отправить" Width="80" Margin="5,0,0,0"
                            IsEnabled="False" Click="SendButton_Click"/>
                </Grid>
            </Grid>
        </Grid>
    </ui:NavigationView>
</Window>





